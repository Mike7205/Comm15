# Skopiuj ten plik do .env i uzupełnij klucze API

# Alpha Vantage – https://alphavantage.co (darmowy)
ALPHA_VANTAGE_KEY=your_key_here

# Finnhub – https://finnhub.io (darmowy)
FINNHUB_KEY=your_key_here

# Twelve Data – https://twelvedata.com (darmowy)
TWELVE_DATA_KEY=your_key_here

# EODHD – https://eodhd.com (darmowy)
EODHD_KEY=your_key_here

# FRED (St. Louis Fed) – https://fred.stlouisfed.org/docs/api/api_key.html (darmowy)
# Wymagany dla: Fed, BoJ, PBOC | ECB dziala bez klucza
FRED_KEY=your_key_here

# CoinGecko – nie wymaga klucza
